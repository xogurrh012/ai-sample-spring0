{{> layout/header}}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-4 shadow-lg border-0 rounded-4">
                <div class="card-body">
                    <h2 class="text-center mb-4 fw-bold text-primary">회원가입</h2>
                    <hr class="mb-4">

                    <form action="/join" method="post">
                        <!-- 아이디 입력 및 중복 체크 -->
                        <div class="mb-3">
                            <label for="username" class="form-label fw-semibold">아이디</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                                <input type="text" name="username" class="form-control border-start-0" id="username" placeholder="아이디를 입력하세요" required>
                                <button type="button" class="btn btn-outline-primary" onclick="checkUsername()">중복 체크</button>
                            </div>
                            <div id="username-msg" class="form-text mt-2"></div>
                        </div>

                        <!-- 비밀번호 -->
                        <div class="mb-3">
                            <label for="password" class="form-label fw-semibold">비밀번호</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                                <input type="password" name="password" class="form-control border-start-0" id="password" placeholder="비밀번호를 입력하세요" required>
                            </div>
                        </div>

                        <!-- 이메일 -->
                        <div class="mb-4">
                            <label for="email" class="form-label fw-semibold">이메일</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                                <input type="email" name="email" class="form-control border-start-0" id="email" placeholder="이메일을 입력하세요" required>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" id="btn-submit" class="btn btn-primary btn-lg fw-bold py-3 shadow-sm rounded-3">회원가입 완료</button>
                        </div>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted small">이미 계정이 있으신가요? <a href="/login-form" class="text-primary text-decoration-none fw-semibold">로그인</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // 아이디 중복 체크 여부 상태 관리
    let isUsernameChecked = false;

    async function checkUsername() {
        const username = document.querySelector("#username").value;
        const msgElement = document.querySelector("#username-msg");
        const btnSubmit = document.querySelector("#btn-submit");

        if (!username || username.trim() === "") {
            msgElement.innerText = "아이디를 입력해주세요.";
            msgElement.classList.add("text-danger");
            msgElement.classList.remove("text-success");
            return;
        }

        try {
            // Fetch API를 사용하여 서버와 비동기 통신
            const response = await fetch(`/api/check-username?username=${username}`);
            const result = await response.json(); // Resp 객체 구조: {status: 200, msg: "성공", body: true/false}

            if (result.body === true) {
                // 사용 가능
                msgElement.innerText = "사용 가능한 아이디입니다.";
                msgElement.classList.remove("text-danger");
                msgElement.classList.add("text-success");
                isUsernameChecked = true;
            } else {
                // 중복됨
                msgElement.innerText = "이미 존재하는 아이디입니다.";
                msgElement.classList.remove("text-success");
                msgElement.classList.add("text-danger");
                isUsernameChecked = false;
            }
        } catch (error) {
            console.error("중복 체크 중 오류 발생:", error);
            msgElement.innerText = "서버 통신 중 오류가 발생했습니다.";
            msgElement.classList.add("text-danger");
        }
    }

    // 아이디 입력값이 변경되면 다시 중복 체크 하도록 초기화
    document.querySelector("#username").addEventListener("input", function() {
        isUsernameChecked = false;
        document.querySelector("#username-msg").innerText = "";
    });

    // 가입 폼 제출 시 최종 확인
    document.querySelector("form").addEventListener("submit", function(e) {
        if (!isUsernameChecked) {
            e.preventDefault();
            alert("아이디 중복 체크를 먼저 진행해주세요.");
        }
    });
</script>

{{> layout/footer}}
